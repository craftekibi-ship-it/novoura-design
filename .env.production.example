# === Novoura Design — ÜRETİM (.env) ===
# Bu dosyayı sunucuda .env olarak kopyalayıp doldur. ASLA git'e commit etme.

APP_NAME="Novoura Design"
APP_ENV=production
APP_KEY=                      # sunucuda: php artisan key:generate
APP_DEBUG=false
APP_URL=https://design.novouracreative.com

APP_LOCALE=tr
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=tr_TR

LOG_CHANNEL=stack
LOG_LEVEL=warning

# --- Veritabanı: canlıda MySQL ---
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=novoura_design
DB_USERNAME=novoura_design
DB_PASSWORD=                  # CyberPanel'de oluşturduğun DB şifresi

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_SECURE_COOKIE=true

QUEUE_CONNECTION=database
CACHE_STORE=database
FILESYSTEM_DISK=local

# --- Anthropic (YENİ anahtar al — eski sohbette açık geçti) ---
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL_SMART=claude-sonnet-4-6
ANTHROPIC_MODEL_FAST=claude-haiku-4-5
ANTHROPIC_VERSION=2023-06-01
